# Variables de Supabase (REQUERIDAS)
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service Role Key (REQUERIDO para crear usuarios)
# Lo encuentras en: Supabase Dashboard > Settings > API > service_role key
# ⚠️ NUNCA COMPARTIR NI SUBIR A GIT - Solo para scripts de backend/testing
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# REPORTE DIARIO POR EMAIL (SUPABASE EDGE)
# ============================================
# Destinatarios reales del reporte diario.
DAILY_REPORT_RECIPIENTS=sarmientoclaudia985@gmail.com,agustinwojtyszyn99@gmail.com

# Remitente verificado en el proveedor de email (Resend).
MAIL_FROM="ServiFood Pedidos <reportes@your-domain.com>"

# API key server-side del proveedor de email. La Edge Function usa Resend vía HTTP.
EMAIL_PROVIDER_API_KEY=your-resend-api-key

# URL pública HTTPS opcional del logo para el HTML del email.
# Recomendado: Supabase Storage público o asset público del frontend deployado.
SERVIFOOD_LOGO_URL=https://your-public-domain.com/servifood-logo.png

# Destinatario opcional para pruebas del reporte con datos reales.
TEST_REPORT_RECIPIENT=agustinwojtyszyn99@gmail.com

# Secreto para invocar manualmente o desde cron la función.
CRON_SECRET=change-me

# ============================================
# CONFIGURACIÓN DE PRUEBAS DE CARGA (OPCIONAL)
# ============================================

# Número de usuarios de prueba a crear
TEST_USERS_COUNT=100

# Usuarios concurrentes en load test
CONCURRENT_USERS=50

# Pedidos que creará cada usuario
ORDERS_PER_USER=3

# Delay en milisegundos entre pedidos del mismo usuario
DELAY_MS=500

# Delay en milisegundos entre inicio de cada usuario
USER_DELAY_MS=100

# ============================================
# UNLIGHTHOUSE / CRAWL AUTH (OPCIONAL)
# ============================================
UNLIGHTHOUSE_SITE=http://localhost:4173
UNLIGHTHOUSE_AUTH_EMAIL=test.user1@servifood.test
UNLIGHTHOUSE_AUTH_PASSWORD=Test123!@#
